# ============================================================
# Backend Configuration Example
# Copy this to application.properties and fill in your secrets
# ============================================================

server.port=${PORT:8080}

# --- PostgreSQL (Neon) ---
spring.datasource.url=${DB_URL:jdbc:postgresql://your-neon-db-url}
spring.datasource.username=${DB_USERNAME:your_db_username}
spring.datasource.password=${DB_PASSWORD:your_db_password}
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.hikari.data-source-properties.prepareThreshold=0

# --- JPA ---
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.open-in-view=false

# --- JWT / Clerk ---
spring.security.oauth2.resourceserver.jwt.issuer-uri=${CLERK_ISSUER_URI:https://your-app-id.clerk.accounts.dev}
jwt.secret=${JWT_SECRET:your_jwt_secret_placeholder_here}
jwt.expiration-ms=86400000

# --- CORS ---
app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:5173}

# --- Mail Configuration (Gmail SMTP) ---
spring.mail.host=${MAIL_HOST:smtp.gmail.com}
spring.mail.port=${MAIL_PORT:587}
spring.mail.username=${MAIL_USERNAME:yourgmail@gmail.com}
spring.mail.password=${MAIL_PASSWORD:your-16-character-app-password}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
spring.mail.properties.mail.smtp.writetimeout=5000
app.mail.from=${RESEND_FROM_EMAIL:your_resend_email@example.com}
app.contact.recipient=${CONTACT_RECIPIENT_EMAIL:your_email@example.com}

# --- File Uploads ---
spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=5MB

# --- Cloudinary ---
cloudinary.cloud-name=${CLOUDINARY_CLOUD_NAME:your_cloudinary_cloud_name}
cloudinary.api-key=${CLOUDINARY_API_KEY:your_cloudinary_api_key}
cloudinary.api-secret=${CLOUDINARY_API_SECRET:your_cloudinary_api_secret}

# --- Logging ---
logging.level.org.springframework.security=WARN
logging.level.com.skillify=INFO

# --- AI Configuration ---
groq.api.key=${GROQ_API_KEY:}
gemini.api.key=${GEMINI_API_KEY:your_gemini_api_key}
